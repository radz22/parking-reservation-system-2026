
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  username   String   @unique
  password   String
  role       Role     @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reservations   ParkingReservation[]

}

enum Role {
  USER
  ADMIN
}