
generator client {
  provider = "prisma-client-js"
}

generator jsonTypes {
  provider = "prisma-json-types-generator"
}

generator typescriptInterfaces {
  provider = "prisma-generator-typescript-interfaces"
}

datasource db {
  provider = "postgresql"
}
enum ReservationStatus {
  PENDING
  RESERVED
  OCCUPIED
  COMPLETED
  CANCELLED
}


enum VehicleType {
  TWO_WHEEL
  FOUR_WHEEL
}
