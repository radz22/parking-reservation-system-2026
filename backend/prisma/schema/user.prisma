
model User {
  id         String   @id @default(uuid())
  username   String   @unique

  email      String   @unique
  password   String
  contact    String
  plateNumber String?
  role       Role     @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reservations   ParkingReservation[]
}


enum Role {
  USER
  ADMIN
}